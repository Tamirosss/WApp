<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WApp.WorkoutPage"
             BackgroundColor="#f8f9fa">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto" 
              Padding="20,20,20,10"
              Grid.Row="0">

            <Button Text="← Back"
                    BackgroundColor="#667eea"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="15,10"
                    FontSize="14"
                    Grid.Column="0"
                    Clicked="OnBackClicked"/>

            <Label Text="My Workouts"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#667eea"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Grid.Column="1"/>

            <Button Text="🚪 Logout"
                    BackgroundColor="#ef4444"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="15,10"
                    FontSize="14"
                    Grid.Column="2"
                    Clicked="OnLogoutClicked"/>
        </Grid>

        <!-- Workouts Container -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="WorkoutsContainer" 
                                 Padding="20" 
                                 Spacing="15"/>
        </ScrollView>
    </Grid>

</ContentPage>